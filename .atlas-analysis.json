  "keyFeatures": [
    "Event-driven architecture with pub/sub event bus",
    "Periodic HTTP health checks with configurable intervals",
    "Time-series metrics storage in TimescaleDB",
    "Email notifications on status changes",
    "CLI for managing monitored URLs",
    "Worker pool pattern for concurrent monitoring",
    "Supervisor-based decision logic with debouncing"
  ],
  "publicApiSurface": [
    "guard - Start the monitoring service",
    "add - Add a new URL to monitor",
    "remove - Remove a monitored URL",
    "list - List all monitored URLs",
    "analysis - Run analysis for a URL"
